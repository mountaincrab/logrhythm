rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user owns everything under their own users/{uid} document tree.
    // Covers profiles, poop_entries, food_entries, note_entries, poop_tags,
    // note_tags — read/written by both the Android app and the web app.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }
  }
}
