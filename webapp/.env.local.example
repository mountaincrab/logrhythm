# Copy this file to .env.local and fill in your Firebase project values.
# IMPORTANT: use the SAME Firebase project as the Android app so data syncs.
# Find these in the Firebase console -> Project settings -> Your apps -> Web app config.
# (If no web app exists yet, add one with the "</>" button — no new project needed.)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
